   "source": [
    "numbers = []\n",
    "n = int(input(\"Enter number of integer: \"))\n",
    "\n",
    "for i in range(n):\n",
    "    num = int(input(\"Enter number: \"))\n",
    "    numbers.append(num)\n",
    "\n",
    "t1 = tuple(numbers)\n",
    "a, b = map(int, input(\"Choice criteria between index: \").split(','))\n",
    "\n",
    "t2 = t1[a:b+1]\n",
    "print(t2)"
   ]

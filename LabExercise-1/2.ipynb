      "Enter number of integer:  5\n",
      "Enter a number:  1\n",
      "Enter a number:  2\n",
      "Enter a number:  3\n",
      "Enter a number:  4\n",
      "Enter a number:  5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sum of all integers = 15\n"
     ]
    }
   ],
   "source": [
    "numbers = []\n",
    "n = int(input(\"Enter number of integer: \"))\n",
    "\n",
    "for i in range(n):\n",
    "    num = int(input(\"Enter a number: \"))\n",
    "    numbers.append(num)\n",
    "\n",
    "t = tuple(numbers)\n",
    "count = 0\n",
    "\n",
    "for i in range(len(t)):\n",
    "    count += t[i]\n",
    "\n",
    "print(\"Sum of all integers =\", count)"
   ]
